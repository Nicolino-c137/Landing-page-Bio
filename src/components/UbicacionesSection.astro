---
import { sucursales } from '../data/sucursales';
---

<section id="sucursales" class="section bg-surface-low flex flex-col items-center text-center">
  <div class="section-inner w-full max-w-6xl mx-auto flex flex-col items-center">

    <!-- Encabezado -->
    <div class="fade-in mb-16 max-w-lg">
      <p class="text-xs font-medium uppercase tracking-[0.22em] text-secondary mb-3">Encontranos</p>
      <h2 class="heading-xl text-on-surface mb-4">Nuestras sucursales</h2>
      <p class="body-lg text-muted">
        Encontrá el oasis más cercano a vos. Lunes a sábado, con turnos online.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 w-full items-stretch">
      {sucursales.map((s, i) => (
        <article class="fade-in bg-surface rounded-2xl border border-surface-high
          flex flex-col items-center text-center gap-6 p-8
          transition-shadow duration-300 hover:shadow-md w-full h-full">

          <!-- Número + nombre -->
          <div class="flex flex-col items-center gap-1">
            <span class="font-display text-4xl font-light text-primary leading-none">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-display text-lg font-medium text-on-surface leading-tight">
              {s.nombre}
            </h3>
          </div>

          <div class="w-10 h-px bg-surface-high shrink-0"></div>

          <!-- Contenido central: flex-1 absorbe diferencia de altura -->
          <div class="flex-1 flex flex-col items-center gap-5 w-full">

            <!-- Dirección → Google Maps: flex justify-center centra el grupo ícono+texto -->
            <a
              href={s.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start justify-center gap-1.5 text-sm text-muted hover:text-primary-dark transition-colors group w-full"
              aria-label={`Ver ${s.nombre} en Google Maps`}
            >
              <svg
                width="14" height="14" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round"
                class="shrink-0 mt-0.5 group-hover:stroke-primary transition-colors"
                aria-hidden="true"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <address class="not-italic leading-snug text-center max-w-[12rem] min-h-[4rem]">
                {s.direccion}
              </address>
            </a>

            <!-- Horario -->
            <div class="flex items-center justify-center gap-1.5 text-sm text-muted">
              <svg
                width="14" height="14" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round"
                class="shrink-0"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span>{s.horario}</span>
            </div>

          </div>

          <a
            href={s.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline justify-center"
            style="margin-bottom: 1rem;"
            aria-label={`Contactar sucursal ${s.nombre} por WhatsApp`}
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>

        </article>
      ))}
    </div>

  </div>
</section>