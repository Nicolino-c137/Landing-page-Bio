---
const navLinks = [
  { href: '/#servicios',  label: 'Servicios' },
  { href: '/#catalogo',   label: 'Precios' },
  { href: '/#galeria',    label: 'Galería' },
  { href: '/#sucursales', label: 'Sucursales' },
];

const RESERVAR = 'https://bioesteticayspa.site.agendapro.com/ar';
const INSTAGRAM = 'https://www.instagram.com/bioesteticayspa_sanjuan';
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50">
  <nav class="grid grid-cols-3 items-center px-6 py-3 max-w-screen-xl mx-auto w-full">

    <!-- Logo -->
    <div class="flex justify-start">
      <a href="/" aria-label="Bio Estética y Spa — inicio">
        <img
          src="/logo_bio.svg"
          alt="Bio Estética y Spa"
          width="120"
          height="120"
          class="h-20 w-auto"
          loading="eager"
        />
      </a>
    </div>

    <!-- Links desktop — centrados -->
    <ul class="hidden md:flex justify-centers items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-xs font-medium uppercase tracking-widest text-on-surface hover:text-primary transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Acciones desktop -->
    <div class="hidden md:flex justify-end items-center gap-4">
      <a
        href={INSTAGRAM}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram de Bio Estética y Spa"
        class="text-muted hover:text-on-surface transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href={RESERVAR} target="_blank" rel="noopener noreferrer" class="btn-primary text-xs py-2.5 px-5">
        Reservar turno
      </a>
    </div>

    <!-- Hamburger mobile -->
    <button
      id="mobile-menu"
      aria-label="Abrir menú"
      aria-expanded="false"
      class="md:hidden col-start-3 justify-self-end flex flex-col gap-1.5 p-2 -mr-2"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

  </nav>

  <!-- Menú mobile -->
  <div
    id="mobile-nav"
    class="md:hidden hidden flex-col items-center gap-6 pb-14 pt-2 px-6 border-t border-surface-high bg-surface"
    role="navigation"
    aria-label="Menú móvil"
  >
    {navLinks.map(link => (
      <a
        href={link.href}
        class="text-sm font-medium uppercase tracking-widest text-on-surface hover:text-primary transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href={INSTAGRAM}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-medium uppercase tracking-widest text-muted hover:text-on-surface transition-colors"
    >
      Instagram
    </a>
    <a href={RESERVAR} target="_blank" rel="noopener noreferrer" class="btn-primary w-full text-center justify-center">
      Reservar turno
    </a>
  </div>
</header>

<script>
  const nav = document.getElementById('main-nav');
  const menuBtn = document.getElementById('mobile-menu');
  const mobileNav = document.getElementById('mobile-nav');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }, { passive: true });

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileNav?.classList.contains('hidden');
    if (isOpen) {
      mobileNav?.classList.add('hidden');
      mobileNav?.classList.remove('flex');
      menuBtn.classList.remove('open');
      menuBtn.setAttribute('aria-expanded', 'false');
    } else {
      mobileNav?.classList.remove('hidden');
      mobileNav?.classList.add('flex');
      menuBtn.classList.add('open');
      menuBtn.setAttribute('aria-expanded', 'true');
    }
  });

  mobileNav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav.classList.add('hidden');
      mobileNav.classList.remove('flex');
      menuBtn?.classList.remove('open');
      menuBtn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
